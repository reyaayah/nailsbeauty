rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── NEW: restrict client updates to safe profile fields only ───
    function isSafeUserUpdate() {
      let allowedFields = [
        'displayName', 'photoURL', 'phoneNumber',
        'wishlist', 'addresses', 'marketingEmail', 'marketingSms',
        'updatedAt'
      ];
      return request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(allowedFields);
    }

    // ─── Users: own data only ──────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isSignedIn() && request.auth.uid == uid;

      // CHANGED: was `allow read, update` — now splits into two rules.
      // loyaltyPoints, referralCode, referralLink can only be written
      // by the Admin SDK (server); clients are restricted to safe fields.
      allow update: if isOwner(uid) && isSafeUserUpdate();

      // User subcollections (orders, cart, etc.)
      match /orders/{orderId} {
        allow read: if isOwner(uid);
      }
      match /cart/{itemId} {
        allow read, write: if isOwner(uid);
      }

      // NEW: points transaction log — append-only from the client
      match /pointsHistory/{txId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid);
        allow update, delete: if false;
      }
    }

    // ─── Global orders: user can read own orders ──────────────────
    match /orders/{orderId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── Wishlists ────────────────────────────────────────────────
    match /wishlists/{uid} {
      allow read: if isOwner(uid);
      match /items/{itemId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ─── Products: public read, admin write (via server SDK) ───────
    match /products/{productId} {
      allow read: if true;
    }

    // ─── Collections: public read ─────────────────────────────────
    match /collections/{collectionId} {
      allow read: if true;
    }

    // ─── Blog: published posts are public ─────────────────────────
    match /blog/{postId} {
      allow read: if resource.data.isPublished == true;
    }

    // ─── Admins: no client reads (admin SDK only) ─────────────────
    match /admins/{adminId} {
      allow read: if isOwner(adminId);
    }

    // NEW: Referrals collection
    // Either party can read their own referral doc.
    // Creation is allowed client-side (inside redeemReferralCode transaction).
    // Immutable after creation.
    match /referrals/{refId} {
      allow read: if isSignedIn() && (
        resource.data.referrerUid == request.auth.uid ||
        resource.data.refereeUid == request.auth.uid
      );
      allow create: if isSignedIn() &&
        request.resource.data.refereeUid == request.auth.uid;
      allow update, delete: if false;
    }

    // ─── Default deny ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}